// This example uses a spherical image pigment to render the Earth.

title = 'Spherical image pigment test'
distance = -5
height = 1

include 'solar-system/ss-setup.igl'

sphere {
    material {
        pigment image 'https://images.unsplash.com/photo-1579353977828-2a4eab540b9a?fm=jpg&q=60&w=3000&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8c2FtcGxlfGVufDB8fDB8fHww'
        ambient 0.4
    }
    rotate Y 220
    rotate Z -23.5
    translate Y 1 
}
